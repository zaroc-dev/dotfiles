layout {

    focus-ring {
        active-color   "#aec6ff"
        inactive-color "#121316"
        urgent-color   "#ffb4ab"
    }

    border {
        active-color   "#aec6ff"
        inactive-color "#121316"
        urgent-color   "#ffb4ab"
    }

    shadow {
        color "#00000070"
    }

    tab-indicator {
        active-color   "#aec6ff"
        inactive-color "#12448f"
        urgent-color   "#ffb4ab"
    }

    insert-hint {
        color "#aec6ff80"
    }
}

recent-windows {
    highlight {
        active-color "#aec6ff"
        urgent-color "#ffb4ab"
    }
}
